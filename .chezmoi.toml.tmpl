{{- $name := promptStringOnce . "name" "Name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $installCasks := true -}}
{{- if hasKey . "install_casks" -}}
{{- $installCasks = .install_casks -}}
{{- end -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    install_casks = {{ $installCasks }}