{{- $mr := index . "modelRoles" | default dict -}}
ask:
  timeout: 0
async:
  enabled: true
browser:
  headless: true
calc:
  enabled: true
checkpoint:
  enabled: true
colorBlindMode: false
compaction:
  handoffSaveToDisk: true
dev:
  autoqa: true
disabledExtensions: []
inspect_image:
  enabled: true
interruptMode: immediate
memories:
  enabled: true
modelRoles:
  commit: {{ get $mr "commit" | default "" | quote }}
  default: {{ get $mr "default" | default "" | quote }}
  plan: {{ get $mr "plan" | default "" | quote }}
  slow: {{ get $mr "slow" | default "" | quote }}
  smol: {{ get $mr "smol" | default "" | quote }}
renderMermaid:
  enabled: true
secrets:
  enabled: true
steeringMode: one-at-a-time
task:
  eager: true
  isolation:
    commits: generic
theme:
  dark: everforest-dark
  light: everforest-light
