{{- $mr := index . "modelRoles" | default dict -}}
ask:
  timeout: 0
browser:
  headless: true
disabledExtensions: []
memories:
  enabled: true
modelRoles:
  commit: {{ get $mr "commit" | default "SET_IN_CHEZMOI_TOML" | quote }}
  default: {{ get $mr "default" | default "SET_IN_CHEZMOI_TOML" | quote }}
  plan: {{ get $mr "plan" | default "SET_IN_CHEZMOI_TOML" | quote }}
  slow: {{ get $mr "slow" | default "SET_IN_CHEZMOI_TOML" | quote }}
  smol: {{ get $mr "smol" | default "SET_IN_CHEZMOI_TOML" | quote }}
theme:
  dark: dracula
  light: alucard
