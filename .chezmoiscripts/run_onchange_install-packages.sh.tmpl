#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
{{ template "brew-shellenv" . }}
brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ else -}}
# Arch Linux (Omarchy): install personal packages via pacman.
# --needed is idempotent; already-installed packages are skipped.
sudo pacman -S --noconfirm --needed {{ range .packages.arch.pkgs }}{{ . }} {{ end }}
{{ end -}}
