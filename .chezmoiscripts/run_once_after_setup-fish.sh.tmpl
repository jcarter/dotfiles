#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
{{ template "brew-shellenv" . }}
FISH_PATH="$(brew --prefix)/bin/fish"
{{ else -}}
FISH_PATH="/usr/bin/fish"
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
# Register fish as an acceptable login shell if not already listed.
grep -qF "$FISH_PATH" /etc/shells || echo "$FISH_PATH" | sudo tee -a /etc/shells > /dev/null

# Switch the current user's default shell to fish.
test "$SHELL" = "$FISH_PATH" || chsh -s "$FISH_PATH"
{{ end -}}

# Apply the Everforest medium Fish syntax theme. Subsequent sessions switch
# between its dark and light variants from conf.d/color-theme.fish.
fish -c 'fish_config theme choose "everforest-medium"'

# One-time tide prompt initialization.  Sets all universal variables so that
# subsequent sessions pick up the right defaults; conf.d/tide.fish overrides
# the handful of layout/icon choices on each session start.
fish -c "tide configure --auto \
  --style='Classic' \
  --prompt_colors='16 colors' \
  --show_time='No' \
  --classic_prompt_separators='Slanted' \
  --powerline_prompt_heads='Slanted' \
  --powerline_prompt_tails='Slanted' \
  --powerline_prompt_style='One line' \
  --prompt_spacing='Compact' \
  --icons='Few icons' \
  --transient='Yes'" > /dev/null
